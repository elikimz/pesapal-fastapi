# Pesaflux credentials — obtain from https://pesaflux.co.ke/user (Linked Accounts)
PESAFLUX_API_KEY=your_pesaflux_api_key_here
PESAFLUX_EMAIL=your_pesaflux_account_email@example.com

# Pesaflux base URL (sandbox and live use the same endpoint)
PESAFLUX_BASE_URL=https://api.pesaflux.co.ke

# Database (PostgreSQL async URL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
